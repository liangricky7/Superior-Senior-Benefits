---
---
<section class="webinar" id="webinar">
  <div class="webinar__content">
    <h2 class="webinar__heading">Interested? Book a Webinar!</h2>

    <div class="webinar__steps">
      <div class="step">
        <div class="step__circle" aria-hidden="true">1</div>
        <p class="step__text">
          Sign-up for a free 30 minute 1-on-1 Webinar, where we'll cover the foundations of
          Medicare and FAQ!
        </p>
      </div>
      <div class="step">
        <div class="step__circle" aria-hidden="true">2</div>
        <p class="step__text">
          Book a follow-up appointment where we will set up your personalized Medicare plan!
        </p>
      </div>
    </div>

    <a href="https://calendar.app.google/tMytHerGDqsZb2Sq5" target="_blank" rel="noopener noreferrer" class="webinar__cta" aria-label="Schedule a Webinar Today (opens in new tab)">
      <img
        src="/images/webinar-calendar-icon.png"
        alt=""
        class="webinar__cta-icon"
        aria-hidden="true"
        width="94"
        height="94"
      />
      <span>Schedule a Webinar Today!</span>
    </a>
  </div>

  <div class="webinar__photo-wrap">
    <img
      src="/images/webinar-photo.png"
      alt="Medicare consultation in progress"
      class="webinar__photo"
      width="790"
      height="409"
    />
  </div>
</section>

<style>
  .webinar {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: center;
    padding: 4rem var(--page-padding);
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .webinar__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 2.5vw, 3rem);
    font-weight: 600;
    line-height: 1.15;
    margin-bottom: 2rem;
  }

  /* ── Steps ── */
  .webinar__steps {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .step {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .step__circle {
    flex-shrink: 0;
    width: 4.5rem;
    height: 4.5rem;
    border-radius: 50%;
    background-color: var(--color-card-tan);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 2.1vw, 2.5rem);
    font-weight: 600;
    line-height: 1;
  }

  .step__text {
    font-family: var(--font-heading);
    font-size: clamp(1rem, 1.15vw, 1.25rem);
    font-weight: 400;
    line-height: 1.4;
  }

  /* ── CTA button ── */
  .webinar__cta {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    background-color: var(--color-primary);
    color: var(--color-text-light);
    padding: 0.75rem 1.75rem 0.75rem 0.875rem;
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 1.9vw, 2rem);
    font-weight: 600;
    white-space: nowrap;
    transition: opacity 0.2s;
  }

  .webinar__cta:hover {
    opacity: 0.88;
  }

  .webinar__cta-icon {
    width: clamp(40px, 3.6vw, 70px);
    height: auto;
  }

  /* ── Photo ── */
  .webinar__photo-wrap {
    flex-shrink: 0;
  }

  .webinar__photo {
    width: clamp(280px, 41.1vw, 790px);
    height: auto;
    object-fit: cover;
  }

  @media (max-width: 1100px) {
    /* Single column: content first, photo full-width below it */
    .webinar {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .webinar__photo {
      width: 100%;
    }
  }

  @media (max-width: 600px) {
    .webinar {
      padding: 3rem var(--page-padding);
      gap: 2rem;
    }

    .webinar__steps {
      margin-bottom: 2rem;
    }

    .step__circle {
      width: 3.5rem;
      height: 3.5rem;
    }

    .webinar__cta {
      width: 100%;
      justify-content: center;
      text-align: center;
      white-space: normal;
    }
  }
</style>
