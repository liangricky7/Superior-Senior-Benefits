---
---
<header class="navbar">
  <a href="/" class="navbar__logo" aria-label="Superior Senior Benefits home">
    <img src="/images/logo-navbar.png" alt="Superior Senior Benefits" width="346" height="96" />
  </a>
  <!-- col-right column — left edge always aligns with hero stats column -->
  <div class="navbar__cta-col">
    <a href="#webinar" class="navbar__cta">Book an Appointment</a>
  </div>
</header>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg);
    border-bottom: 7px solid var(--color-primary);
    /* Same 2-col grid as .hero so CTA left-edge = stats left-edge */
    display: grid;
    grid-template-columns: 1fr var(--col-right);
    align-items: center;
    min-height: 4.7rem; /* 4.27rem × 1.10 */
  }

  .navbar__logo {
    padding-left: var(--hero-pad);
    display: flex;
    align-items: center;
  }

  .navbar__logo img {
    height: 3.62rem; /* scales with navbar */
    width: auto;
  }

  /* Right column — button is inset with margins on all sides */
  .navbar__cta-col {
    display: flex;
    align-items: center;
    height: 100%;
    padding: clamp(0.35rem, 0.6vw, 0.75rem) clamp(0.5rem, 1.5vw, 1.875rem) clamp(0.35rem, 0.6vw, 0.75rem) clamp(0.25rem, 0.4vw, 0.5rem);
  }

  .navbar__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    background-color: var(--color-primary);
    color: var(--color-text-light);
    font-family: var(--font-heading);
    font-size: clamp(0.8rem, 1vw, 1.25rem);
    font-weight: 400;
    text-align: center;
    white-space: nowrap;
    transition: opacity 0.2s;
  }

  .navbar__cta:hover {
    opacity: 0.88;
  }

  @media (max-width: 900px) {
    .navbar {
      grid-template-columns: 1fr auto;
      padding: 0 var(--hero-pad);
    }

    .navbar__logo {
      padding-left: 0;
    }

    .navbar__cta-col {
      padding: 0.5rem 0;
    }

    .navbar__cta {
      padding: 0.5rem 1rem;
      width: auto;
    }
  }

  @media (max-width: 600px) {
    .navbar {
      min-height: 3.75rem;
    }

    .navbar__logo img {
      height: 2.5rem;
    }

    .navbar__cta {
      font-size: 0.8rem;
      padding: 0.5rem 0.75rem;
    }
  }
</style>
